---
import { Image } from 'astro:assets';
import imgGiocodelleparti from '../assets/IlgiocodellepartiCop.jpg';
import imgAmore from '../assets/amore.jpg';
import imgVendetta from '../assets/vendetta.jpg';
import imgBene from '../assets/bene.jpg';
---

<section class="section libri-section" aria-labelledby="libri-title">
  <div class="container narrow">
    <p class="section-label">Scrittura</p>
    <h2 id="libri-title" class="section-title">Libri</h2>

    <p class="section-subtitle">
      Testi nati da esperienza, attrito, ricerca.
    </p>

    <div class="book-list">

      <!-- Книга U -->
      <a href="https://www.edizionimontag.it/catalogo/il-gioco-delle-parti/" target="_blank" rel="noopener noreferrer" class="book-card">
        <div class="book-flex">
          <div class="book-image-wrapper">
            <Image src={imgGiocodelleparti} alt="Il gioco delle parti" width={300} height={450} class="book-cover" />
          </div>
          <div class="book-content">
            <h3 class="book-title">Il gioco delle parti</h3>
            <p class="book-desc">Un'analisi acuta delle maschere sociali e della ricerca di verità nel quotidiano.</p>
          </div>
        </div>
      </a>

      <!-- Книга 1 -->
      <a href="https://www.amazon.it/Lamore-indecente-Ferdinando-Balzarro/dp/B0FZNPK53R/" target="_blank" rel="noopener noreferrer" class="book-card">
        <div class="book-flex">
          <div class="book-image-wrapper">
            <Image src={imgAmore} alt="L'amore indecente" width={300} height={450} class="book-cover" />
          </div>
          <div class="book-content">
            <h3 class="book-title">L’amore indecente</h3>
            <p class="book-desc">Pathos, tensione, contraddizione. Un intreccio passionale що esplora i confini dell'animo umano.</p>
          </div>
        </div>
      </a>

      <!-- Книга 2 -->
      <a href="https://www.amazon.it/Vendetta-infinita-Ferdinando-Balzarro/dp/B0CSMBBY2Y/" target="_blank" rel="noopener noreferrer" class="book-card">
        <div class="book-flex">
          <div class="book-image-wrapper">
            <Image src={imgVendetta} alt="Vendetta infinita" width={300} height={450} class="book-cover" />
          </div>
          <div class="book-content">
            <h3 class="book-title">Vendetta infinita</h3>
            <p class="book-desc">Romanzo recente. Quando il passato ritorna con la forza di una tempesta marziale.</p>
          </div>
        </div>
      </a>

      <!-- Книга 3 -->
      <a href="https://www.amazon.it/bene-male-Pensieri-maestro/dp/8895687442/" target="_blank" rel="noopener noreferrer" class="book-card">
        <div class="book-flex">
          <div class="book-image-wrapper">
            <Image src={imgBene} alt="Il bene... il male" width={300} height={450} class="book-cover" />
          </div>
          <div class="book-content">
            <h3 class="book-title">Tra bene e male</h3>
            <p class="book-desc">Pensiero, etica, esperienza. Un’esplorazione profonda attraverso gli occhi del Maestro.</p>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>

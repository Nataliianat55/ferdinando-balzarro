---

import { Image } from 'astro:assets';
import karateDetail from '../assets/karate-deta.jpg';
import event1 from '../assets/Ivent 1.jpeg';
import event2 from '../assets/Ivent 2.jpeg'; // Додайте цей рядок
---
---

<section class="section karate-section" aria-labelledby="karate-title">
  <div class="container narrow karate-block">
    <div class="karate-image reveal-item">
      <Image
        src={karateDetail}
        alt="Dettaglio di pratica karate"
        width={800}
        height={500}
        format="webp"
        loading="lazy"
      />
      <div class="image-overlay"></div>
    </div>

    <div class="karate-copy reveal-item">
      <p class="section-label">Karate</p>

      <h2 id="karate-title" class="karate-title">
        Il karate non addolcisce.
      </h2>

      <p class="karate-accent">
        Azzera il superfluo.
      </p>

      <p class="karate-body">
        Non come esibizione, non come posa: il gesto come rigore,
        controllo e presenza.
      </p>

      <article class="karate-item stage-item">
        <h3>Stage Domenicali</h3>
        <p>Da settembre in poi ogni domenica a Bologna presso lo Sport Vilage in via S. Donato Bologna ci saranno stage di approfondimento su vari temi inerenti al karate.</p>
      </article>

      <div class="karate-info">
        <article class="karate-item">
          <h3>Pratica</h3>
          <p>Disciplina del corpo, precisione del gesto, responsabilità interiore.</p>
        </article>

        <article class="karate-item">
          <h3>Orientamento</h3>
          <p>Una ricerca che attraversa tecnica, attenzione e trasformazione.</p>
        </article>

        <article class="karate-item">
          <h3>Città</h3>
          <p>Bologna, Sport Village (via S. Donato).</p>
        </article>
      </div>
    </div>
  </div>
</section>


<section class="events-section" aria-labelledby="events-title">
  <div class="container narrow events-block">
    <h2 id="events-title" class="events-title">Prossimi Stage</h2>
    
    <div class="events-grid">
      <!-- Перша подія -->
      <article class="event-card reveal-item">
        <Image 
          src={event1} 
          alt="Stage di Karate a Cesenatico, 30 agosto" 
          width={600}
          height={400}
          format="webp"
          loading="lazy"
        />
      </article>

      <!-- Друга подія (нова) -->
      <article class="event-card reveal-item">
        <Image 
          src={event2} 
          alt="PIU' SU C'E' SOLO IL CIELO" 
          width={600}
          height={400}
          format="webp"
          loading="lazy"
        />
      </article>
    </div>
  </div>
</section>

<style>
  /* СТИЛІ ЗАЛИШАЮТЬСЯ БЕЗ ЗМІН, ЯК ВИ І НАДСИЛАЛИ */
  .events-section { padding: 80px 20px; background-color: #09090b; }
  .events-title { text-align: center; color: #ffffff; font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 3rem; }
  .events-grid { display: grid; gap: 2rem; grid-template-columns: 1fr; }
  .event-card img { width: 100%; height: auto; border-radius: 12px; border: 1px solid rgba(63, 63, 70, 0.5); transition: transform 0.3s ease; }
  .event-card img:hover { transform: scale(1.02); }
  @media (min-width: 768px) { .events-grid { grid-template-columns: 1fr 1fr; } }

  .karate-section { position: relative; padding: 100px 20px; background-color: #09090b; color: #e4e4e7; overflow: hidden; }
  .container.narrow { max-width: 1200px; margin: 0 auto; }
  .karate-block { display: grid; gap: 3rem; align-items: center; }
  .karate-image { position: relative; border-radius: 16px; overflow: hidden; }
  .karate-image img { width: 100%; display: block; aspect-ratio: 16 / 10; object-fit: cover; filter: grayscale(0.6) brightness(0.8) contrast(1.1); transition: filter 0.5s ease; }
  .image-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(9, 9, 11, 0.4), transparent); }
  .karate-copy { width: 100%; max-width: 36rem; }
  .section-label { color: #C5A059; text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.85rem; font-weight: 600; margin-bottom: 15px; }
  .karate-title { margin: 0 0 0.5rem; color: #ffffff; font-family: 'Playfair Display', serif; font-size: clamp(2.4rem, 6vw, 4rem); line-height: 1.05; }
  .karate-accent { margin: 0 0 1.5rem; color: #C5A059; font-family: 'Playfair Display', serif; font-size: clamp(1.4rem, 3vw, 1.8rem); font-style: italic; }
  .karate-body { margin: 0; max-width: 35ch; color: #a1a1aa; font-size: 1.05rem; line-height: 1.6; }
  .karate-info { margin-top: 3rem; display: grid; gap: 1.2rem; }
  .karate-item { padding: 24px; background-color: rgba(39, 39, 42, 0.4); border: 1px solid rgba(63, 63, 70, 0.5); border-radius: 12px; }
  .karate-item h3 { margin: 0 0 0.8rem; color: #f4f4f5; font-family: 'Playfair Display', serif; font-size: 1.25rem; }
  .stage-item { border-color: #C5A059; }
  .reveal-item { opacity: 0; transform: translateY(30px); transition: opacity 0.8s, transform 0.8s; }
  .reveal-item.is-visible { opacity: 1; transform: translateY(0); }
  @media (min-width: 900px) {
    .karate-block { grid-template-columns: 1fr 1fr; gap: 4rem; }
    .karate-info { grid-template-columns: repeat(2, 1fr); }
    .stage-item { grid-column: span 2; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal-item').forEach((item) => observer.observe(item));
</script>

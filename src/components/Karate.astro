---
const karateImage = `${import.meta.env.BASE_URL}karate-detail.jpg`;
---

<section class="section" aria-labelledby="karate-title">
  <div class="container narrow karate-block">
    <div class="karate-image">
      <img
        src={karateImage}
        alt="Dettaglio del karate: pugno, cintura e gesto"
        loading="lazy"
      />
    </div>

    <div class="karate-copy">
      <p class="section-label">Karate</p>
      <h2 id="karate-title">Il karate non addolcisce.</h2>

      <p>Azzera il superfluo.</p>

      <p>
        Non come esibizione, non come posa:
        il gesto come rigore, controllo e presenza.
      </p>

      <div class="karate-info">
        <article class="karate-item">
          <h3>Pratica</h3>
          <p>Disciplina del corpo, precisione del gesto, responsabilità interiore.</p>
        </article>

        <article class="karate-item">
          <h3>Orientamento</h3>
          <p>Una ricerca che attraversa tecnica, attenzione e trasformazione.</p>
        </article>

        <article class="karate-item">
          <h3>Città</h3>
          <p>Bologna</p>
        </article>
      </div>
    </div>
  </div>
</section>

---
// Секція Visione (Filo conduttore)
---

<section class="section filo-section" aria-labelledby="filo-title">
  <div class="container narrow filo-content">
    <p class="section-label reveal-item">Visione</p>
    
    <h2 id="filo-title" class="filo-title reveal-item">Non una biografia.</h2>
    
    <p class="filo-accent reveal-item">
      Una traiettoria.
    </p>

    <p class="filo-body reveal-item">
      Scrittura, pratica, esperienza:<br />
      forme diverse, stessa esigenza di rigore e presenza.
    </p>
  </div>
</section>

<style>
  /* Базові налаштування секції з великими відступами для ефекту "паузи" */
  .filo-section {
    padding: 140px 20px;
    background-color: #09090b;
    color: #e4e4e7;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .filo-content {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-label {
    color: #C5A059;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 20px;
  }

  .filo-title {
    color: #ffffff;
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 8vw, 5rem); /* Величезний розмір на десктопі, адаптивний на мобільному */
    line-height: 1.1;
    margin: 0 0 10px 0;
  }

  .filo-accent {
    color: #C5A059;
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-style: italic; /* Курсив для підкреслення "траєкторії" */
    margin: 0 0 30px 0;
  }

  .filo-body {
    color: #a1a1aa;
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 45ch;
    margin: 0;
  }

  /* Анімації появи з каскадною затримкою */
  .reveal-item {
    opacity: 0;
    transform: translateY(25px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Каскад: кожний наступний рядок з'являється трохи пізніше */
  .filo-content .reveal-item:nth-child(1) { transition-delay: 0.1s; }
  .filo-content .reveal-item:nth-child(2) { transition-delay: 0.25s; }
  .filo-content .reveal-item:nth-child(3) { transition-delay: 0.4s; }
  .filo-content .reveal-item:nth-child(4) { transition-delay: 0.55s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.2,
      rootMargin: '0px 0px -10% 0px'
    }
  );

  document.querySelectorAll('.reveal-item').forEach((item) => {
    observer.observe(item);
  });
</script>

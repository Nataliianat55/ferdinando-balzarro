---
// Секція Coordinate / Tre linee di forza
---

<section class="section coordinate-section" aria-labelledby="volti-title">
  <div class="container">
    <div class="section-header reveal-item">
      <p class="section-label">Coordinate</p>
      <h2 id="volti-title" class="section-title">Tre linee di forza</h2>
    </div>

    <div class="cards-grid">
      <article class="card reveal-item">
        <div class="card-content">
          <h3 class="card-title">Karate</h3>
          <p class="card-desc">Rigore. Precisione. Presenza.</p>
        </div>
      </article>

      <article class="card reveal-item">
        <div class="card-content">
          <h3 class="card-title">Scrittura</h3>
          <p class="card-desc">Attrito, visione, contraddizione.</p>
        </div>
      </article>

      <article class="card reveal-item">
        <div class="card-content">
          <h3 class="card-title">Ricerca</h3>
          <p class="card-desc">Meno posa. Più verità.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  /* Базові налаштування секції */
  .coordinate-section {
    padding: 100px 20px;
    background-color: #09090b; /* Наш фірмовий глибокий фон */
    color: #e4e4e7;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Заголовок секції */
  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-label {
    color: #C5A059; /* Бронзовий акцент */
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .section-title {
    color: #ffffff;
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin: 0;
    line-height: 1.1;
  }

  /* Сітка карток */
  .cards-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .cards-grid {
      /* На планшетах і вище - 3 колонки в один ряд */
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Дизайн карток (синхронізовано з Libri та Karate) */
  .card {
    background-color: rgba(39, 39, 42, 0.4);
    border: 1px solid rgba(63, 63, 70, 0.5);
    border-radius: 16px;
    padding: 40px 30px;
    text-align: center;
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 220px;
  }

  .card:hover {
    background-color: rgba(39, 39, 42, 0.8);
    border-color: rgba(197, 160, 89, 0.4); /* Бронзова рамка при наведенні */
    transform: translateY(-8px); /* Трохи сильніше підняття для цих карток */
    box-shadow: 0 12px 40px -10px rgba(0, 0, 0, 0.5);
  }

  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    color: #f4f4f5;
    margin: 0 0 15px 0;
    transition: color 0.3s ease;
  }

  .card:hover .card-title {
    color: #C5A059; /* Заголовок стає бронзовим */
  }

  .card-desc {
    color: #a1a1aa;
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Анімації появи */
  .reveal-item {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Каскадна затримка для карток, щоб вони з'являлися по черзі */
  .cards-grid .card:nth-child(1) { transition-delay: 0.1s; }
  .cards-grid .card:nth-child(2) { transition-delay: 0.25s; }
  .cards-grid .card:nth-child(3) { transition-delay: 0.4s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.15,
      rootMargin: '0px 0px -10% 0px'
    }
  );

  document.querySelectorAll('.reveal-item').forEach((item) => {
    observer.observe(item);
  });
</script>

---
const heroImage = `${import.meta.env.BASE_URL}ferdinando-hero.jpg`;
---

<section class="hero hero--cinematic">
  <div class="hero-bg">
    <img src={heroImage} alt="" aria-hidden="true" loading="eager" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Bologna · Scrittura · Karate</p>
      <h1>Ferdinando Balzarro</h1>
      <p class="lead">
        Scrittura, pratica, visione.
        Una presenza che tiene insieme corpo,
        linguaggio e tensione interiore.
      </p>
      <a class="button" href="#contatti">Contatti</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 7rem 0 6rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.85) contrast(1.06) brightness(0.39);
    transform: scale(1.02);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(12, 12, 15, 0.92) 0%, rgba(12, 12, 15, 0.7) 42%, rgba(12, 12, 15, 0.42) 100%),
      radial-gradient(circle at 20% 20%, rgba(201, 122, 61, 0.10), transparent 35%);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    min-height: min(84vh, 920px);
    display: grid;
    align-items: center;
  }

  .hero-copy {
    max-width: 38rem;
  }

  .eyebrow {
    color: var(--color-accent);
  }

  h1 {
    color: var(--color-text);
    text-shadow: 0 6px 30px rgba(0, 0, 0, 0.35);
  }

  .lead {
    color: rgba(243, 241, 234, 0.78);
  }

  .button {
    background: var(--color-accent);
    color: #0c0c0f;
    box-shadow:
      0 0 0 1px var(--color-accent-soft),
      0 12px 30px var(--color-accent-glow);
  }

  .button:hover {
    background: var(--color-accent-strong);
  }

  @media (min-width: 900px) {
    .hero {
      padding: 8rem 0 7rem;
    }

    .hero-copy {
      max-width: 44rem;
    }
  }

  @media (max-width: 899px) {
    .hero-bg img {
      object-position: 72% 38%;
      filter: saturate(0.82) contrast(1.06) brightness(0.34);
      transform: scale(1.06);
    }

    .hero-overlay {
      background:
        linear-gradient(180deg, rgba(10, 10, 12, 0.82) 0%, rgba(10, 10, 12, 0.58) 52%, rgba(10, 10, 12, 0.38) 100%),
        linear-gradient(90deg, rgba(10, 10, 12, 0.72) 0%, rgba(10, 10, 12, 0.34) 48%, rgba(10, 10, 12, 0.16) 100%);
    }
  }
</style>

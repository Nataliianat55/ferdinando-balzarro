---
const heroImage = `${import.meta.env.BASE_URL}ferdinando-hero.jpg`;
---

<section class="hero hero--cinematic">
  <div class="hero-bg">
    <img src={heroImage} alt="Ferdinando Balzarro" aria-hidden="true" loading="eager" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Bologna · Scrittura · Karate</p>
      <h1>Ferdinando Balzarro</h1>
      <p class="lead">
        Scrittura, pratica, visione. Una presenza che tiene insieme corpo, linguaggio e tensione interiore.
      </p>
      <a class="button" href="#contatti">Contatti</a>
    </div>
  </div>
</section>

<style>
  /* Головний контейнер */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh; /* Висота на весь екран */
    min-height: 650px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #09090b; 
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Налаштування фотографії - Мобільна версія */
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Зміщуємо фокус на самий верх, щоб зберегти очі в кадрі */
    object-position: center 10%; 
    filter: brightness(0.8) contrast(1.1);
  }

  /* Градієнт для мобільної версії: дуже темний знизу (під текстом), прозорий зверху */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(9, 9, 11, 1) 0%, rgba(9, 9, 11, 0.8) 35%, transparent 100%);
  }

  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Сітка контенту - Мобільна версія */
  .hero-grid {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Притискаємо текст донизу */
    padding-bottom: 12vh; /* Безпечний відступ від нижнього краю екрана */
    padding-top: 100px;
  }

  .hero-copy {
    max-width: 100%;
    text-align: center; 
    display: flex;
    flex-direction: column;
    align-items: center; 
  }

  /* Типографіка */
  .eyebrow {
    color: #C5A059; 
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3.5rem, 12vw, 5.5rem); 
    line-height: 1.05;
    color: #ffffff;
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.6); 
  }

  .lead {
    color: #e4e4e7;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 32rem;
  }

  /* Елегантна кнопка - Зробили її залитою за замовчуванням для кращого контрасту на телефоні */
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 36px;
    background: #C5A059; 
    color: #09090b;
    border: 1px solid #C5A059;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.4s ease;
  }

  .button:hover {
    background: transparent;
    color: #C5A059;
  }

  /* Налаштування для десктопу (від 900px) */
  @media (min-width: 900px) {
    .hero-grid {
      justify-content: center; 
      padding-bottom: 0;
    }

    .hero-copy {
      max-width: 44rem;
      text-align: left; 
      align-items: flex-start; 
    }

    /* На десктопі повертаємо фокус вправо */
    .hero-bg img {
      object-position: 70% center; 
    }

    /* Десктопний градієнт: темний зліва, прозорий справа */
    .hero-overlay {
      background: linear-gradient(90deg, #09090b 0%, rgba(9, 9, 11, 0.85) 45%, transparent 100%);
    }
  }
</style>

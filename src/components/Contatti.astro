<section id="contatti" class="section" aria-labelledby="contatti-title">
  <div class="container narrow">
    <p class="section-label">Contatti</p>
    <h2 id="contatti-title">Per libri, incontri, dialoghi</h2>

    <p>
      Bologna. Per contatti diretti, libri, pratica e conversazioni.
    </p>

    <ul class="contact-list">
      <li>Email: <a href="mailto:balzarro.nando@gmail.com">balzarro.nando@gmail.com</a></li>
      <li>Facebook: <a href="https://www.facebook.com/share/1DuhTeJWbM/" target="_blank" rel="noopener noreferrer">Pagina Facebook</a></li>
      <li>Città di riferimento: Bologna</li>
      <li class="phone-row">
        <button type="button" class="button button-phone" aria-expanded="false" aria-controls="phone-value">
          Mostra numero
        </button>
        <span id="phone-value" hidden>368 536 411</span>
      </li>
    </ul>
  </div>
</section>

<script>
  const phoneButton = document.querySelector('.button-phone');
  const phoneValue = document.querySelector('#phone-value');

  if (phoneButton && phoneValue) {
    phoneButton.addEventListener('click', () => {
      const isHidden = phoneValue.hasAttribute('hidden');

      if (isHidden) {
        phoneValue.removeAttribute('hidden');
        phoneButton.setAttribute('aria-expanded', 'true');
        phoneButton.textContent = 'Nascondi numero';
      } else {
        phoneValue.setAttribute('hidden', '');
        phoneButton.setAttribute('aria-expanded', 'false');
        phoneButton.textContent = 'Mostra numero';
      }
    });
  }
</script>

<style>
  .phone-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  #phone-value {
    font-weight: 600;
    letter-spacing: 0.04em;
  }
</style>
